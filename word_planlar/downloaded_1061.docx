                    <div class="flex items-center gap-2 sm:gap-4" x-data="headerSearch()" x-init="init()">
                        
                        <div class="hidden md:block">
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                    </svg>
                                </div>
                                <input
                                    x-ref="desktopSearchInput"
                                    type="text"
                                    x-model="query"
                                    @input.debounce.200ms="performSearch"
                                    @focus="query.length >= 2 && (showResults = true)"
                                    @keydown.escape="showResults = false; query = ''"
                                    @keydown.enter.prevent="navigateToFirst"
                                    @keydown.arrow-down.prevent="highlightNext"
                                    @keydown.arrow-up.prevent="highlightPrev"
                                    placeholder="Ne arıyorsunuz?"
                                    class="w-72 rounded-full border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 py-1.5 pl-9 pr-8 text-sm placeholder-gray-500 dark:placeholder-gray-400 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 focus:bg-white dark:focus:bg-gray-700 outline-none"
                                >
                                
                                <button x-show="query.length > 0" @click="clearSearch" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>

                                
                                <div x-show="showResults"
                                     x-cloak
                                     x-transition:enter="transition ease-out duration-100"
                                     x-transition:enter-start="opacity-0 -translate-y-1"
                                     x-transition:enter-end="opacity-100 translate-y-0"
                                     x-transition:leave="transition ease-in duration-75"
                                     x-transition:leave-start="opacity-100 translate-y-0"
                                     x-transition:leave-end="opacity-0 -translate-y-1"
                                     :class="showAllResults ? 'max-h-[36rem]' : 'max-h-80'"
                                     class="absolute top-full left-0 right-0 mt-1 bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 overflow-y-auto z-50">

                                    
                                    <div x-show="loadingData" class="p-4 text-center text-xs text-gray-500 dark:text-gray-400">
                                        <svg class="animate-spin h-4 w-4 mx-auto mb-1" fill="none" viewBox="0 0 24 24">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                        </svg>
                                        Hazırlanıyor...
                                    </div>

                                    
                                    <template x-if="!loadingData && results.length > 0">
                                        <div>
                                            <div class="px-3 pt-2 pb-1">
                                                <span class="text-xs font-semibold text-gray-400 dark:text-gray-400 uppercase tracking-wider">Öneriler</span>
                                            </div>
                                            <template x-for="(item, index) in results" :key="item.id">
                                                <a :href="item.route.includes('{') ? '/search?q=' + encodeURIComponent(query) : item.route"
                                                   :class="highlightedIndex === index ? 'bg-primary-50 dark:bg-primary-900/20' : 'hover:bg-gray-50 dark:hover:bg-gray-700/50'"
                                                   class="flex items-center gap-3 px-3 py-2 transition-colors border-b border-gray-100 dark:border-gray-700 last:border-b-0"
                                                   @mouseover="highlightedIndex = index">
                                                    <div :class="getCategoryColor(item.category)" class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0">
                                                        <i :class="'bi ' + getCategoryIconClass(item.category)" class="text-sm leading-none"></i>
                                                    </div>
                                                    <div class="flex-1 min-w-0">
                                                        <p class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate" x-html="highlight(item.title)"></p>
                                                        <p class="text-xs text-gray-400 dark:text-gray-400" x-text="getCategoryLabel(item.category)"></p>
                                                    </div>
                                                    <svg class="w-3.5 h-3.5 text-gray-300 dark:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                                    </svg>
                                                </a>
                                            </template>
                                            
                                            <div class="px-3 py-2 border-t border-gray-100 dark:border-gray-700">
                                                <button @click="searchAll()" type="button"
                                                        class="flex items-center gap-2 text-xs text-primary-600 dark:text-primary-400 hover:underline w-full text-left">
                                                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                                    </svg>
                                                    "<span x-text="query"></span>" için tüm sonuçlara bak
                                                </button>
                                            </div>
                                        </div>
                                    </template>

                                    
                                    <template x-if="!loadingData && results.length === 0 && query.length >= 2">
                                        <div class="p-4">
                                            <p class="text-xs text-gray-400 dark:text-gray-400 text-center mb-2">Eşleşme bulunamadı</p>
                                            <button @click="searchAll()" type="button"
                                                    class="flex items-center justify-center gap-2 text-xs text-primary-600 dark:text-primary-400 hover:underline w-full">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                                </svg>
                                                Genel aramada ara: "<span x-text="query"></span>"
                                            </button>
                                        </div>
                                    </template>

                                    
                                    <template x-if="showAllResults">
                                        <div class="border-t border-gray-200 dark:border-gray-600">
                                            <div x-show="loadingAll" class="p-4 text-center text-xs text-gray-500 dark:text-gray-400">
                                                <svg class="animate-spin h-4 w-4 mx-auto mb-1 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24">
                                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                                </svg>
                                                Aranıyor...
                                            </div>
                                            <template x-if="!loadingAll">
                                                <div>
                                                    <template x-if="getAllDbResultsList().length === 0">
                                                        <p class="p-4 text-xs text-gray-400 dark:text-gray-400 text-center">Veritabanında sonuç bulunamadı</p>
                                                    </template>
                                                    <template x-for="group in getAllDbResultsList()" :key="group.tur">
                                                        <div>
                                                            <div class="px-3 py-1 text-xs font-semibold text-gray-500 dark:text-gray-300 uppercase tracking-wider bg-gray-50 dark:bg-gray-700 sticky top-0">
                                                                <span x-text="getTurLabel(group.tur)"></span>
                                                            </div>
                                                            <template x-for="item in group.items" :key="item.id">
                                                                <a :href="item.url"
                                                                   class="flex items-center gap-2 px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors border-b border-gray-100 dark:border-gray-700 last:border-b-0">
                                                                    <i class="bi bi-arrow-right-short text-gray-300 dark:text-gray-500 text-base flex-shrink-0"></i>
                                                                    <span x-text="item.name" class="text-sm text-gray-700 dark:text-gray-200 truncate"></span>
                                                                </a>
                                                            </template>
                                                        </div>
                                                    </template>
                                                </div>
                                            </template>
                                        </div>
                                    </template>
                                </div>
                            </div>
                        </div>

                        
                        <button
                            @click="mobileSearchOpen = true"
                            class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 md:hidden"
                        >
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </button>

                        
                        <div
                            x-show="mobileSearchOpen"
                            x-cloak
                            class="md:hidden fixed inset-0 z-50"
                        >
                            
                            <div
                                x-show="mobileSearchOpen"
                                x-transition:enter="transition ease-out duration-200"
                                x-transition:enter-start="opacity-0"
                                x-transition:enter-end="opacity-100"
                                x-transition:leave="transition ease-in duration-150"
                                x-transition:leave-start="opacity-100"
                                x-transition:leave-end="opacity-0"
                                @click="mobileSearchOpen = false; clearSearch()"
                                class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm"
                            ></div>

                            
                            <div
                                x-show="mobileSearchOpen"
                                x-transition:enter="transition ease-out duration-200"
                                x-transition:enter-start="opacity-0 -translate-y-4"
                                x-transition:enter-end="opacity-100 translate-y-0"
                                x-transition:leave="transition ease-in duration-150"
                                x-transition:leave-start="opacity-100 translate-y-0"
                                x-transition:leave-end="opacity-0 -translate-y-4"
                                class="relative bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700/50 p-4 max-h-[80vh] overflow-y-auto"
                            >
                                <div class="flex items-center gap-3">
                                    <div class="flex-1 relative">
                                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                            </svg>
                                        </div>
                                        <input
                                            x-ref="mobileSearchInput"
                                            x-init="$watch('mobileSearchOpen', value => { if(value) setTimeout(() => $refs.mobileSearchInput.focus(), 100) })"
                                            type="text"
                                            x-model="query"
                                            @input.debounce.200ms="performSearch"
                                            @keydown.escape="mobileSearchOpen = false; clearSearch()"
                                            @keydown.enter.prevent="navigateToFirst"
                                            @keydown.arrow-down.prevent="highlightNext"
                                            @keydown.arrow-up.prevent="highlightPrev"
                                            placeholder="Ne arıyorsunuz?"
                                            class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 py-2.5 pl-10 pr-10 text-sm placeholder-gray-500 dark:placeholder-gray-400 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 outline-none"
                                        >
                                        
                                        <button x-show="query.length > 0" @click="clearSearch" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                            </svg>
                                        </button>
                                    </div>
                                    <button
                                        @click="mobileSearchOpen = false; clearSearch()"
                                        class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800"
                                    >
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                        </svg>
                                    </button>
                                </div>

                                
                                <div x-show="query.length >= 2" class="mt-4">
                                    
                                    <div x-show="loadingData" class="py-6 text-center text-xs text-gray-500 dark:text-gray-400">
                                        <svg class="animate-spin h-5 w-5 mx-auto mb-1" fill="none" viewBox="0 0 24 24">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                        </svg>
                                        Hazırlanıyor...
                                    </div>

                                    
                                    <template x-if="!loadingData && results.length > 0">
                                        <div>
                                            <div class="px-1 pb-2">
                                                <span class="text-xs font-semibold text-gray-400 dark:text-gray-400 uppercase tracking-wider">Öneriler</span>
                                            </div>
                                            <div class="space-y-1">
                                                <template x-for="(item, index) in results" :key="item.id">
                                                    <a :href="item.route.includes('{') ? '/search?q=' + encodeURIComponent(query) : item.route"
                                                       @click="mobileSearchOpen = false"
                                                       :class="highlightedIndex === index ? 'bg-primary-50 dark:bg-primary-900/20' : 'bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700'"
                                                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors">
                                                        <div :class="getCategoryColor(item.category)" class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0">
                                                            <i :class="'bi ' + getCategoryIconClass(item.category)" class="text-sm leading-none"></i>
                                                        </div>
                                                        <div class="flex-1 min-w-0">
                                                            <p class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate" x-html="highlight(item.title)"></p>
                                                            <p class="text-xs text-gray-400 dark:text-gray-400" x-text="getCategoryLabel(item.category)"></p>
                                                        </div>
                                                        <svg class="w-3.5 h-3.5 text-gray-300 dark:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                                        </svg>
                                                    </a>
                                                </template>
                                            </div>
                                            <div class="pt-3 mt-2 border-t border-gray-100 dark:border-gray-700">
                                                <button @click="searchAll()" type="button"
                                                        class="flex items-center gap-2 text-xs text-primary-600 dark:text-primary-400 hover:underline w-full text-left">
                                                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                                    </svg>
                                                    "<span x-text="query"></span>" için tüm sonuçlara bak
                                                </button>
                                            </div>
                                        </div>
                                    </template>

                                    
                                    <template x-if="!loadingData && results.length === 0">
                                        <div class="py-6 text-center">
                                            <p class="text-sm text-gray-400 dark:text-gray-400 mb-3">Eşleşme bulunamadı</p>
                                            <button @click="searchAll()" type="button"
                                                    class="inline-flex items-center gap-2 text-xs text-primary-600 dark:text-primary-400 hover:underline">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                                </svg>
                                                Genel aramada ara: "<span x-text="query"></span>"
                                            </button>
                                        </div>
                                    </template>

                                    
                                    <template x-if="showAllResults">
                                        <div class="border-t border-gray-200 dark:border-gray-600 mt-2">
                                            <div x-show="loadingAll" class="py-4 text-center text-xs text-gray-500 dark:text-gray-400">
                                                <svg class="animate-spin h-4 w-4 mx-auto mb-1 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24">
                                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                                </svg>
                                                Aranıyor...
                                            </div>
                                            <template x-if="!loadingAll">
                                                <div>
                                                    <template x-if="getAllDbResultsList().length === 0">
                                                        <p class="py-4 text-xs text-gray-400 dark:text-gray-400 text-center">Veritabanında sonuç bulunamadı</p>
                                                    </template>
                                                    <template x-for="group in getAllDbResultsList()" :key="group.tur">
                                                        <div>
                                                            <div class="px-1 py-1.5 text-xs font-semibold text-gray-500 dark:text-gray-300 uppercase tracking-wider bg-gray-50 dark:bg-gray-800 sticky top-0">
                                                                <span x-text="getTurLabel(group.tur)"></span>
                                                            </div>
                                                            <template x-for="item in group.items" :key="item.id">
                                                                <a :href="item.url"
                                                                   @click="mobileSearchOpen = false"
                                                                   class="flex items-center gap-2 px-1 py-2.5 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors border-b border-gray-100 dark:border-gray-700 last:border-b-0">
                                                                    <i class="bi bi-arrow-right-short text-gray-300 dark:text-gray-500 text-base flex-shrink-0"></i>
                                                                    <span x-text="item.name" class="text-sm text-gray-700 dark:text-gray-200 truncate"></span>
                                                                </a>
                                                            </template>
                                                        </div>
                                                    </template>
                                                </div>
                                            </template>
                                        </div>
                                    </template>
                                </div>

                                
