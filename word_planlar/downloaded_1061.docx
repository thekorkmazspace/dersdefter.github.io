    <script>
        function headerSearch() {
            return {
                query: '',
                results: [],
                allItems: [],
                loadingData: true,
                showResults: false,
                mobileSearchOpen: false,
                highlightedIndex: -1,
                csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,
                allDbResults: {},
                showAllResults: false,
                loadingAll: false,

                async init() {
                    try {
                        const cached = sessionStorage.getItem('intentKeywordsV2');
                        if (cached) {
                            const parsed = JSON.parse(cached);
                            this.allItems = parsed.items || parsed;
                        } else {
                            const res = await fetch('https://defterdoldur.com/search/intents');
                            if (res.ok) {
                                const data = await res.json();
                                this.allItems = data.items || [];
                                sessionStorage.setItem('intentKeywordsV2', JSON.stringify(data));
                            }
                        }
                    } catch (e) {
                        console.warn('intent-keywords yüklenemedi:', e);
                    }
                    this.loadingData = false;
                },

                performSearch() {
                    this.showAllResults = false;
                    this.allDbResults = {};
                    if (this.query.length < 2) {
                        this.results = [];
                        this.showResults = false;
                        this.highlightedIndex = -1;
                        return;
                    }

                    const q = this.query.toLocaleLowerCase('tr-TR').trim();

                    const scored = this.allItems
                        .map(item => {
                            let score = 0;
                            if (item.title.toLocaleLowerCase('tr-TR') === q) score += 100;
                            else if (item.title.toLocaleLowerCase('tr-TR').includes(q)) score += 30;
                            (item.keywords || []).forEach(kw => {
                                if (kw.toLocaleLowerCase('tr-TR') === q) score += 50;
                                else if (kw.toLocaleLowerCase('tr-TR').includes(q)) score += 20;
                            });
                            (item.intents || []).forEach(intent => {
                                if (intent.toLocaleLowerCase('tr-TR').includes(q)) score += 10;
                            });
                            score *= (item.weight || 1);
                            return { ...item, score };
                        })
                        .filter(i => i.score > 0)
                        .sort((a, b) => b.score - a.score)
                        .slice(0, 6);

                    this.results = scored;
                    this.showResults = true;
                    this.highlightedIndex = scored.length > 0 ? 0 : -1;
                },

                navigateToFirst() {
                    if (this.results.length === 0) {
                        window.location.href = '/search?q=' + encodeURIComponent(this.query);
                        return;
                    }
                    const item = this.highlightedIndex >= 0 ? this.results[this.highlightedIndex] : this.results[0];
                    window.location.href = item.route.includes('{')
                        ? '/search?q=' + encodeURIComponent(this.query)
                        : item.route;
                },

                highlightNext() {
                    if (this.results.length === 0) return;
                    this.highlightedIndex = (this.highlightedIndex + 1) % this.results.length;
                },

                highlightPrev() {
                    if (this.results.length === 0) return;
                    this.highlightedIndex = (this.highlightedIndex - 1 + this.results.length) % this.results.length;
                },

                highlight(text) {
                    if (!text || !this.query) return text;
                    const escaped = this.query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                    const regex = new RegExp(`(${escaped})`, 'gi');
                    return text.replace(regex, '<mark class="bg-yellow-100 dark:bg-yellow-800/40 text-yellow-800 dark:text-yellow-200 rounded px-0.5">$1</mark>');
                },

                clearSearch() {
                    this.query = '';
                    this.results = [];
                    this.showResults = false;
                    this.showAllResults = false;
                    this.allDbResults = {};
                },

                async searchAll() {
                    if (!this.query || this.query.length < 2) return;
                    this.loadingAll = true;
                    this.showAllResults = true;
                    this.showResults = true;
                    try {
                        const res = await fetch('/search?q=' + encodeURIComponent(this.query), {
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        const data = await res.json();
                        this.allDbResults = data.results || {};
                    } catch (e) {}
                    this.loadingAll = false;
                },

                getAllDbResultsList() {
                    return Object.entries(this.allDbResults)
                        .filter(([, items]) => items && (Array.isArray(items) ? items.length > 0 : Object.keys(items).length > 0))
                        .map(([tur, items]) => ({
                            tur,
                            items: Array.isArray(items) ? items : Object.values(items)
                        }));
                },

                getTurLabel(tur) {
                    const labels = {
                        'sinif': 'Sınıflar', 'ders': 'Dersler', 'kazanim': 'Kazanımlar',
                        'etkinlik': 'Etkinlikler', 'program': 'Programlar',
                        'dokuman': 'Dökümanlar', 'paylasim': 'Paylaşımlar',
                        'yillik': 'Yıllık Planlar', 'gunluk': 'Günlük Planlar', 'menu': 'Menü',
                    };
                    return labels[tur] || tur;
                },

                getCategoryColor(category) {
                    const map = {
                        'plan':  'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400',
                        'sinav': 'bg-rose-100 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400',
                        'bep':   'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400',
                        'belge': 'bg-violet-100 dark:bg-violet-900/30 text-violet-600 dark:text-violet-400',
                        'genel': 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400',
                    };
                    return map[category] || map['genel'];
                },

                getCategoryIconClass(category) {
                    const icons = {
                        'plan':  'bi-file-earmark-text',
                        'sinav': 'bi-clipboard-check',
                        'bep':   'bi-heart-pulse',
                        'belge': 'bi-file-earmark',
                        'genel': 'bi-link-45deg',
                    };
                    return icons[category] || icons['genel'];
                },

                getCategoryLabel(category) {
                    const labels = {
                        'plan':  'Planlar',
                        'sinav': 'Sınavlar',
                        'bep':   'BEP',
                        'belge': 'Belgeler',
                        'genel': 'Genel',
                    };
                    return labels[category] || category;
                },
            }
        }
    </script>

    
    <script>
        function floatingButtons() {
            return {
                isVisible: false,
                isHovered: false,
                menuOpen: false,
                showBackToTop: false,
                scrollTimeout: null,
                hideDelay: 2000, // 2 saniye sonra kaybolsun

                init() {
                    window.addEventListener('scroll', () => this.handleScroll());
                },

                handleScroll() {
                    // Scroll olduğunda göster
                    this.isVisible = true;

                    // Back to top butonu için (200px scroll sonrası göster)
                    this.showBackToTop = window.scrollY > 200;

                    // Önceki timeout'u temizle
                    if (this.scrollTimeout) {
                        clearTimeout(this.scrollTimeout);
                    }

                    // Scroll durduğunda gizle (hover veya menü açık değilse)
                    this.scrollTimeout = setTimeout(() => {
                        if (!this.isHovered && !this.menuOpen) {
                            this.isVisible = false;
                        }
                    }, this.hideDelay);
                }
            }
        }
    </script>

    
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>

    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    
    <script src="https://defterdoldur.com/back/js/footer.js?v=1.1.8"></script>

    
    <script>
    (function() {
        // Anasayfa ve bazı sayfaları hariç tut
        const excludedPaths = ['/', '/anasayfa', '/login', '/register', '/logout', '/password'];
        const currentPath = window.location.pathname;

        // Hariç tutulan sayfaları kontrol et
        if (excludedPaths.some(path => currentPath === path || currentPath.startsWith(path + '/'))) {
            return;
        }

        // Sayfa başlığını al (temizle)
        let pageTitle = document.title.replace(' - Öğretmen Yardımcı Platformu', '').replace(' - Defterdoldur', '').trim();
        if (!pageTitle || pageTitle === 'Defterdoldur') {
            return;
        }

        // localStorage'dan mevcut listeyi al
        let recentPages = [];
        try {
            const stored = localStorage.getItem('recentPages');
            if (stored) {
                recentPages = JSON.parse(stored);
            }
        } catch (e) {
            recentPages = [];
        }

        // Aynı URL varsa kaldır (en son ziyaret için güncelleme)
        recentPages = recentPages.filter(page => page.url !== currentPath);

        // Yeni sayfayı başa ekle
        recentPages.unshift({
            url: currentPath,
            title: pageTitle,
            timestamp: Date.now()
        });

        // Maximum 10 kayıt tut
        if (recentPages.length > 10) {
            recentPages = recentPages.slice(0, 10);
        }

        // localStorage'a kaydet
        try {
            localStorage.setItem('recentPages', JSON.stringify(recentPages));
        } catch (e) {
            // localStorage dolu veya hata
        }
    })();
    </script>

    
    <script>
function intentSearchCard() {
    return {
        query: '',
        results: [],
        allItems: [],
        loadingData: true,
        showResults: false,
        listening: false,
        voiceSupported: false,
        recognition: null,
        highlightedIndex: -1,
        allDbResults: {},
        showAllResults: false,
        loadingAll: false,
       placeholder: 'Aradığınızı bir cümleyle anlatın...',
        randomQuote: '',

        async init() {

            // JSON yükle (sessionStorage cache ile)
            try {
                const cached = sessionStorage.getItem('intentKeywordsV2');
                if (cached) {
                    const parsed = JSON.parse(cached);
                    this.allItems = parsed.items || parsed;
                    if (parsed.quotes && parsed.quotes.length) {
                       this.randomQuote = parsed.quotes[Math.floor(Math.random() * parsed.quotes.length)];
                        this.placeholder = this.randomQuote;
                    }
                } else {
                    const res = await fetch('https://defterdoldur.com/search/intents');
                    if (res.ok) {
                        const data = await res.json();
                        this.allItems = data.items || [];
                        if (data.quotes && data.quotes.length) {
                          this.randomQuote = data.quotes[Math.floor(Math.random() * data.quotes.length)];
                          this.placeholder = this.randomQuote;
                        }
                        sessionStorage.setItem('intentKeywordsV2', JSON.stringify(data));
                    }
                }
            } catch (e) {
                console.warn('intent-keywords.json yüklenemedi:', e);
            }
            this.loadingData = false;

            // Web Speech API — ücretsiz, tarayıcı built-in, tr-TR
            const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (SR) {
                this.voiceSupported = true;
                this.recognition = new SR();
                this.recognition.lang = 'tr-TR';
                this.recognition.continuous = false;
                this.recognition.interimResults = true;

                this.recognition.onresult = (e) => {
                    const lastResult = e.results[e.results.length - 1];
                    const transcript = lastResult[0].transcript;
                    this.query = transcript;
                    if (lastResult.isFinal) {
                        this.performSearch();
                    }
                };

                this.recognition.onend = () => {
                    this.listening = false;
                };

                this.recognition.onerror = () => {
                    this.listening = false;
                };
            }
        },

        toggleVoice() {
            if (!this.recognition) return;
            if (this.listening) {
                this.recognition.stop();
                this.listening = false;
            } else {
                this.listening = true;
                this.showResults = false;
                this.query = '';
                this.recognition.start();
            }
        },

        performSearch() {
            // Yeni arama — DB sonuçlarını sıfırla
            this.showAllResults = false;
            this.allDbResults = {};

            if (this.query.length < 2) {
                this.results = [];
                this.showResults = false;
                this.highlightedIndex = -1;
                return;
            }

            const q = this.query.toLocaleLowerCase('tr-TR').trim();

            const scored = this.allItems
                .map(item => {
                    let score = 0;
                    if (item.title.toLocaleLowerCase('tr-TR') === q) score += 100;
                    else if (item.title.toLocaleLowerCase('tr-TR').includes(q)) score += 30;
                    (item.keywords || []).forEach(kw => {
                        if (kw.toLocaleLowerCase('tr-TR') === q) score += 50;
                        else if (kw.toLocaleLowerCase('tr-TR').includes(q)) score += 20;
                    });
                    (item.intents || []).forEach(intent => {
                        if (intent.toLocaleLowerCase('tr-TR').includes(q)) score += 10;
                    });
                    score *= (item.weight || 1);
                    return { ...item, score };
                })
                .filter(i => i.score > 0)
                .sort((a, b) => b.score - a.score)
                .slice(0, 6);

            this.results = scored;
            this.showResults = true;
            this.highlightedIndex = scored.length > 0 ? 0 : -1;
        },

        async searchAll() {
            if (!this.query || this.query.length < 2) return;
            this.loadingAll = true;
            this.showAllResults = true;
            try {
                const res = await fetch('/search?q=' + encodeURIComponent(this.query), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await res.json();
                this.allDbResults = data.results || {};
            } catch (e) {}
            this.loadingAll = false;
        },

        getAllDbResultsList() {
            return Object.entries(this.allDbResults)
                .filter(([, items]) => items && (Array.isArray(items) ? items.length > 0 : Object.keys(items).length > 0))
                .map(([tur, items]) => ({
                    tur,
                    items: Array.isArray(items) ? items : Object.values(items)
                }));
        },

        getTurLabel(tur) {
            const labels = {
                'sinif': 'Sınıflar', 'ders': 'Dersler', 'kazanim': 'Kazanımlar',
                'etkinlik': 'Etkinlikler', 'program': 'Programlar',
                'dokuman': 'Dökümanlar', 'paylasim': 'Paylaşımlar',
                'yillik': 'Yıllık Planlar', 'gunluk': 'Günlük Planlar', 'menu': 'Menü',
            };
            return labels[tur] || tur;
        },

        navigateToFirst() {
            if (this.results.length === 0) {
                window.location.href = '/search?q=' + encodeURIComponent(this.query);
                return;
            }
            const item = this.highlightedIndex >= 0 ? this.results[this.highlightedIndex] : this.results[0];
            if (item.route.includes('{')) {
                window.location.href = '/search?q=' + encodeURIComponent(this.query);
            } else {
                window.location.href = item.route;
            }
        },

        highlightNext() {
            if (this.results.length === 0) return;
            this.highlightedIndex = (this.highlightedIndex + 1) % this.results.length;
        },

        highlightPrev() {
            if (this.results.length === 0) return;
            this.highlightedIndex = (this.highlightedIndex - 1 + this.results.length) % this.results.length;
        },

        highlight(text) {
            if (!text || !this.query) return text;
            const escaped = this.query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            const regex = new RegExp(`(${escaped})`, 'gi');
            return text.replace(regex, '<mark class="bg-yellow-100 dark:bg-yellow-800/40 text-yellow-800 dark:text-yellow-200 rounded px-0.5">$1</mark>');
        },

        getCategoryColor(category) {
            const map = {
                'plan':  'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400',
                'sinav': 'bg-rose-100 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400',
                'bep':   'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400',
                'belge': 'bg-violet-100 dark:bg-violet-900/30 text-violet-600 dark:text-violet-400',
                'genel': 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400',
            };
            return map[category] || map['genel'];
        },

        getCategoryIconClass(category) {
            const icons = {
                'plan':  'bi-file-earmark-text',
                'sinav': 'bi-clipboard-check',
                'bep':   'bi-heart-pulse',
                'belge': 'bi-file-earmark',
                'genel': 'bi-link-45deg',
            };
            return icons[category] || icons['genel'];
        },

        getCategoryLabel(category) {
            const labels = {
                'plan':  'Planlar',
                'sinav': 'Sınavlar',
                'bep':   'BEP',
                'belge': 'Belgeler',
                'genel': 'Genel',
            };
            return labels[category] || category;
        },
    }
}
</script>

    
    <script>
        // Mobile Columns Component (Swipe + Butonlarla geçi)
        function mobileColumns() {
            return {
                currentColumn: 1, // Default orta sütun (0: sol, 1: orta, 2: sağ)
                touchStartX: 0,
                touchStartY: 0,
                touchEndX: 0,
                touchEndY: 0,
                isSwiping: false,
                swipeThreshold: 80, // Minimum swipe mesafesi (px)

                init() {
                    // localStorage'dan son seçili stunu al
                    try {
                        const saved = localStorage.getItem('anasayfaMobileColumn');
                        if (saved !== null) {
                            const col = parseInt(saved);
                            if (col >= 0 && col <= 2) {
                                this.currentColumn = col;
                            }
                        }
                    } catch (e) {}
                },

                goTo(index) {
                    if (index < 0 || index > 2) return;
                    this.currentColumn = index;
                    // localStorage'a kaydet
                    try {
                        localStorage.setItem('anasayfaMobileColumn', index);
                    } catch (e) {}
                },

                handleTouchStart(e) {
                    // Horizontal scroll alanlarında swipe'ı devre dışı bırak
                    const target = e.target;
                    const scrollableParent = target.closest('.overflow-x-auto, .son-paylasimlar-scroll');
                    if (scrollableParent) {
                        return; // Horizontal scroll alanında swipe yapma
                    }

                    this.touchStartX = e.touches[0].clientX;
                    this.touchStartY = e.touches[0].clientY;
                    this.isSwiping = false;
                },

                handleTouchMove(e) {
                    if (!this.touchStartX || !this.touchStartY) return;

                    const currentX = e.touches[0].clientX;
                    const currentY = e.touches[0].clientY;
                    const diffX = this.touchStartX - currentX;
                    const diffY = this.touchStartY - currentY;

                    // Yatay hareket dikey hareketten fazlaysa swipe başladı
                    if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 10) {
                        this.isSwiping = true;
                        // Sayfa scroll'unu engelle
                        e.preventDefault();
                    }
                },

                handleTouchEnd(e) {
                    if (!this.touchStartX || !this.touchStartY) return;

                    this.touchEndX = e.changedTouches[0].clientX;
                    this.touchEndY = e.changedTouches[0].clientY;

                    const diffX = this.touchStartX - this.touchEndX;
                    const diffY = this.touchStartY - this.touchEndY;

                    // Swipe değilse veya yeterli mesafe yoksa iptal et
                    if (!this.isSwiping || Math.abs(diffX) < this.swipeThreshold) {
                        this.resetTouch();
                        return;
                    }

                    // Yatay hareket dikey hareketten fazla olmalı
                    if (Math.abs(diffX) > Math.abs(diffY)) {
                        if (diffX > 0) {
                            // Sola swipe (sağa git)
                            this.swipeNext();
                        } else {
                            // Sağa swipe (sola git)
                            this.swipePrev();
                        }
                    }

                    this.resetTouch();
                },

                swipeNext() {
                    if (this.currentColumn < 2) {
                        this.goTo(this.currentColumn + 1);
                    }
                },

                swipePrev() {
                    if (this.currentColumn > 0) {
                        this.goTo(this.currentColumn - 1);
                    }
                },

                resetTouch() {
                    this.touchStartX = 0;
                    this.touchStartY = 0;
                    this.touchEndX = 0;
                    this.touchEndY = 0;
                    this.isSwiping = false;
                }
            }
        }

        // Info Carousel Component
        function infoCarousel() {
            return {
                currentSlide: 0,
                totalSlides: 20,
                autoplayInterval: null,

                init() {
                    if (this.totalSlides > 1) {
                        this.startAutoplay();
                    }
                },

                startAutoplay() {
                    this.autoplayInterval = setInterval(() => {
                        this.next();
                    }, 10000);
                },

                stopAutoplay() {
                    if (this.autoplayInterval) {
                        clearInterval(this.autoplayInterval);
                    }
                },

                next() {
                    this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
                },

                prev() {
                    this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
                },

                goTo(index) {
                    this.currentSlide = index;
                    this.stopAutoplay();
                    this.startAutoplay();
                }
            }
        }

        // Ders Bitiş Sayacı + Hızlı Ders Modalı
        function lessonCountdown(startTimeStr, endTimeStr, lessonId, sinifAdi, lessonName) {
            return {
                remaining: '',
                ended: false,
                progress: 0,
                timer: null,
                lessonId, sinifAdi, lessonName,
                startTime: startTimeStr, endTime: endTimeStr,

                // Modal state
                modalOpen: false,
                activeTab: 'note',
                noteTitle: '', noteSaving: false, noteSaved: false, noteError: '',
                classNotes: [], loadingNotes: false, notesLoaded: false,
                siniflar: [], loadingSiniflar: false,
                selectedSinif: null, students: [], loadingStudents: false,
                pickedStudent: null, picking: false,
                rozetSistemleri: [], rozetLoaded: false,

                // Drag state (web only)
                isMobile: false,
                dragX: 0, dragY: 0,

                start() {
                    this.update();
                    this.timer = setInterval(() => this.update(), 1000);
                },
                update() {
                    const now = new Date();
                    const [sh, sm] = startTimeStr.split(':').map(Number);
                    const [eh, em] = endTimeStr.split(':').map(Number);
                    const startT = new Date(now); startT.setHours(sh, sm, 0, 0);
                    const endT = new Date(now); endT.setHours(eh, em, 0, 0);
                    const total = endT - startT;
                    const diff = endT - now;
                    if (diff <= 0) {
                        this.remaining = '';
                        this.progress = 100;
                        this.ended = true;
                        clearInterval(this.timer);
                        return;
                    }
                    const elapsed = now - startT;
                    this.progress = Math.min(100, Math.max(0, Math.round((elapsed / total) * 100)));
                    const mins = Math.floor(diff / 60000);
                    const secs = Math.floor((diff % 60000) / 1000);
                    this.remaining = mins + ':' + String(secs).padStart(2, '0');
                },
                openQuickModal() {
                    this.isMobile = window.innerWidth < 640;
                    this.activeTab = 'note';
                    this.modalOpen = true;
                    this.noteSaved = false; this.noteError = '';
                    if (!this.isMobile) {
                        this.dragX = Math.max(20, Math.round((window.innerWidth - 520) / 2));
                        this.dragY = Math.max(20, Math.round((window.innerHeight - 540) / 2));
                    }
                    document.body.style.overflow = 'hidden';
                    this.loadSiniflar();
                    this.loadRozetSistemleri();
                    this.loadClassNotes();
                },
                closeModal() {
                    this.modalOpen = false;
                    this.noteTitle = '';
                    this.noteSaved = false; this.noteError = '';
                    this.pickedStudent = null;
                    document.body.style.overflow = '';
                },
                switchTab(tab) {
                    this.activeTab = tab;
                    if (tab === 'student' && !this.selectedSinif && this.siniflar.length > 0) {
                        this.autoSelectCurrentSinif();
                    }
                },
                autoSelectCurrentSinif() {
                    if (!this.siniflar.length) return;
                    const parts = (this.sinifAdi || '').split('/');
                    const sinif = parts[0]?.trim();
                    const sube = parts[1]?.trim();
                    const match = sinif && sube
                        ? this.siniflar.find(s => String(s.sinif) === String(sinif) && String(s.sube) === String(sube))
                        : null;
                    this.selectSinif(match || this.siniflar[0]);
                },
                startDrag(e) {
                    if (this.isMobile || e.button !== 0) return;
                    e.preventDefault();
                    const offsetX = e.clientX - this.dragX;
                    const offsetY = e.clientY - this.dragY;
                    const onMove = (ev) => {
                        this.dragX = Math.max(0, Math.min(window.innerWidth - 520, ev.clientX - offsetX));
                        this.dragY = Math.max(0, Math.min(window.innerHeight - 60, ev.clientY - offsetY));
                    };
                    const onUp = () => {
                        document.removeEventListener('mousemove', onMove);
                        document.removeEventListener('mouseup', onUp);
                    };
                    document.addEventListener('mousemove', onMove);
                    document.addEventListener('mouseup', onUp);
                },
                async saveNote() {
                    const text = this.noteTitle.trim();
                    if (!text) return;
                    this.noteSaving = true; this.noteError = '';
                    try {
                        const title = text.split('\n')[0].substring(0, 100);
                        const todayDate = new Date().toISOString().split('T')[0];
                        const params = new URLSearchParams({
                            _token: document.querySelector('meta[name="csrf-token"]').content,
                            title,
                            description: text,
                            sinif_adi: this.sinifAdi,
                            ders_id: this.lessonId,
                            ders_adi: this.lessonName,
                            priority: 'medium',
                            due_date: todayDate,
                        });
                        const r = await fetch('/ogretmen/gorev-listesi/sinif-notu/ekle', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: params.toString()
                        });
                        const data = await r.json();
                        if (data.success) {
                            this.noteSaved = true;
                            this.noteTitle = '';
                            this.notesLoaded = false;
                            this.loadClassNotes();
                        } else {
                            this.noteError = data.message || 'Hata oluştu';
                        }
                    } catch(e) { this.noteError = 'Bağlantı hatası'; }
                    finally { this.noteSaving = false; }
                },
                async loadClassNotes() {
                    if (this.notesLoaded || !this.lessonId) return;
                    this.loadingNotes = true;
                    try {
                        const params = new URLSearchParams({ ders_id: this.lessonId, sinif_adi: this.sinifAdi });
                        const r = await fetch('/ogretmen/gorev-listesi/sinif-notlari?' + params.toString());
                        const data = await r.json();
                        if (data.success) this.classNotes = data.notes.slice(0, 5);
                    } catch(e) {}
                    this.notesLoaded = true;
                    this.loadingNotes = false;
                },
                async loadRozetSistemleri() {
                    if (this.rozetLoaded) return;
                    try {
                        const r = await fetch('/sinif-yonetim/get/rozet-sistemleri');
                        this.rozetSistemleri = await r.json();
                    } catch(e) {}
                    this.rozetLoaded = true;
                },
                async loadSiniflar() {
                    if (this.siniflar.length > 0) return;
                    this.loadingSiniflar = true;
                    try {
                        const r = await fetch('/editor/siniflarim-json');
                        const data = await r.json();
                        if (data.status === 'success') {
                            this.siniflar = data.data;
                            if (this.activeTab === 'student' && !this.selectedSinif) {
                                this.autoSelectCurrentSinif();
                            }
                        }
                    } catch(e) {}
                    this.loadingSiniflar = false;
                },
                async selectSinif(s) {
                    this.selectedSinif = s; this.pickedStudent = null; this.picking = false;
                    this.loadingStudents = true; this.students = [];
                    try {
                        const r = await fetch(`/editor/sinif-ogrencileri-json?sinif=${encodeURIComponent(s.sinif)}&sube=${encodeURIComponent(s.sube)}`);
                        const data = await r.json();
                        if (data.status === 'success') this.students = data.data;
                    } catch(e) {}
                    this.loadingStudents = false;
                },
                pickRandom() {
                    if (!this.students.length || this.picking) return;
                    this.picking = true;
                    let count = 0;
                    const interval = setInterval(() => {
                        this.pickedStudent = this.students[Math.floor(Math.random() * this.students.length)];
                        count++;
                        if (count >= 15) { clearInterval(interval); this.picking = false; }
                    }, 80);
                }
            }
        }

        // Main Page Data
        function anasayfaData() {
            return {
                init() {
                    // Initialization code
                },

                goToKazanim(slug, lessonId, name) {
                    // Kazanımlar sayfasına yönlendir (plandetay route'u)
                    window.location.href = '/plandetay/f/' + lessonId + '/' + name;
                },

                shareApp() {
                    if (navigator.share) {
                        navigator.share({
                            title: 'Defterdoldur.com',
                            text: 'Öğretmenler için kapsamlı yardımcı platform',
                            url: window.location.origin
                        });
                    } else {
                        // Fallback - copy to clipboard
                        navigator.clipboard.writeText(window.location.origin);
                        alert('Link panoya kopyalandı!');
                    }
                }
            }
        }

        // Son Ziyaret Edilen Sayfalar Component
        function recentPagesComponent() {
            return {
                pages: [],
                init() {
                    this.loadPages();
                },
                loadPages() {
                    try {
                        const stored = localStorage.getItem('recentPages');
                        if (stored) {
                            this.pages = JSON.parse(stored);
                            // Zaman bilgilerini güncelle
                            this.pages = this.pages.map(page => ({
                                ...page,
                                visited_at: this.timeAgo(page.timestamp)
                            }));
                        }
                    } catch (e) {
                        this.pages = [];
                    }
                },
                timeAgo(timestamp) {
                    const now = Date.now();
                    const diff = now - timestamp;
                    const minutes = Math.floor(diff / 60000);
                    const hours = Math.floor(diff / 3600000);
                    const days = Math.floor(diff / 86400000);

                    if (minutes < 1) return 'Az önce';
                    if (minutes < 60) return minutes + ' dk önce';
                    if (hours < 24) return hours + ' saat önce';
                    if (days < 7) return days + ' gün önce';
                    return new Date(timestamp).toLocaleDateString('tr-TR');
                }
            }
        }

        // Akademik Takvim Component (GitHub Tarzı)
        function akademikTakvimComponent() {
            return {
                progress: {
                    elapsedPercent: '0',
                    remainingPercent: '0',
                    elapsedWeeks: 0,
                    totalWeeks: 0,
                    weeks: []
                },

                // Tatil dönemleri (backend'den geliyor)
                holidays: [{"start":"2025-11-10","end":"2025-11-14","name":"1. Dönem Ara Tatili","type":"tatil_ara"},{"start":"2026-01-19","end":"2026-01-30","name":"Yarıyıl Tatili","type":"tatil_yariyil"},{"start":"2026-03-16","end":"2026-03-20","name":"2. Dönem Ara Tatili","type":"tatil_ara"}],

                init() {
                    this.calculateProgress();
                },

                isHolidayWeek(weekStartDate) {
                    const weekStart = weekStartDate.getTime();
                    const weekEnd = weekStart + (7 * 24 * 60 * 60 * 1000);

                    for (const holiday of this.holidays) {
                        const holidayStart = new Date(holiday.start).getTime();
                        const holidayEnd = new Date(holiday.end).getTime() + (24 * 60 * 60 * 1000);

                        // Hafta tatil dönemiyle kesişiyor mu?
                        if (weekStart < holidayEnd && weekEnd > holidayStart) {
                            return holiday;
                        }
                    }
                    return null;
                },

                calculateProgress() {
                    const startDate = new Date('2025-09-08 00:00:00');
                    const endDate = new Date('2026-06-26 23:59:59');
                    const now = new Date();

                    const startTime = startDate.getTime();
                    const endTime = endDate.getTime();
                    const nowTime = now.getTime();

                    const totalDuration = endTime - startTime;
                    const elapsed = nowTime - startTime;
                    const remaining = endTime - nowTime;

                    if (totalDuration <= 0) return;

                    // Toplam hafta sayısını hesapla
                    const totalWeeks = Math.ceil(totalDuration / (1000 * 60 * 60 * 24 * 7));
                    const elapsedWeeks = Math.floor(elapsed / (1000 * 60 * 60 * 24 * 7));
                    const currentWeekIndex = Math.min(elapsedWeeks, totalWeeks - 1);

                    this.progress.totalWeeks = totalWeeks;
                    this.progress.elapsedWeeks = Math.min(elapsedWeeks, totalWeeks);
                    this.progress.elapsedPercent = Math.min(100, Math.max(0, (elapsed / totalDuration) * 100)).toFixed(0);
                    this.progress.remainingPercent = Math.min(100, Math.max(0, (remaining / totalDuration) * 100)).toFixed(0);

                    // Hafta kutularını oluştur
                    this.progress.weeks = [];
                    for (let i = 0; i < totalWeeks; i++) {
                        const weekStartDate = new Date(startTime + (i * 7 * 24 * 60 * 60 * 1000));
                        const holiday = this.isHolidayWeek(weekStartDate);
                        const isCurrent = (i === currentWeekIndex && nowTime >= startTime && nowTime <= endTime);

                        let type = 'remaining';
                        let holidayType = null;

                        // Önce bu hafta mı kontrol et
                        if (isCurrent) {
                            type = 'current';
                        } else if (holiday) {
                            type = 'holiday';
                            holidayType = holiday.type; // tatil_ara veya tatil_yariyil
                        } else if (i < elapsedWeeks) {
                            type = 'elapsed';
                        }

                        // Tatil bilgisini title için sakla
                        let title = 'Hafta ' + (i + 1);
                        if (isCurrent) {
                            title = 'Bu Hafta - Hafta ' + (i + 1);
                        } else if (holiday) {
                            title = holiday.name + ' - Hafta ' + (i + 1);
                        }

                        this.progress.weeks.push({
                            type,
                            holidayType,
                            title
                        });
                    }
                }
            }
        }

        // Son Dosyalarım Component
        function sonDosyalarimComponent() {
            return {
                documents: [],
                loading: true,

                async loadDocuments() {
                    try {
                        this.loading = true;
                        const response = await fetch('/user/belgelerim-json', {
                            headers: {
                                'Accept': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            credentials: 'same-origin'
                        });

                        if (response.ok) {
                            const data = await response.json();
                            if (data.status && data.data) {
                                this.documents = data.data;
                            }
                        }
                    } catch (error) {
                        console.error('Dosyalar yüklenirken hata:', error);
                    } finally {
                        this.loading = false;
                    }
                },

                getIcon(type) {
                    const icons = {
                        'sok': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>',
                        'bep': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>',
                        'veli': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>',
                        'plan': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>',
                        'gunluk': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>',
                        'zumre': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>',
                        'sinav': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>',
                        'online_sinav': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>',
                        'gorev': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>',
                        'dokuman': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>',
                        'analiz': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>',
                        'performans': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>',
                        'kulup': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>'
                    };
                    return icons[type] || icons['dokuman'];
                },

                getIconBgClass(type) {
                    const classes = {
                        'sok': 'bg-blue-100 dark:bg-blue-900/30',
                        'bep': 'bg-purple-100 dark:bg-purple-900/30',
                        'veli': 'bg-pink-100 dark:bg-pink-900/30',
                        'plan': 'bg-amber-100 dark:bg-amber-900/30',
                        'gunluk': 'bg-cyan-100 dark:bg-cyan-900/30',
                        'zumre': 'bg-indigo-100 dark:bg-indigo-900/30',
                        'sinav': 'bg-red-100 dark:bg-red-900/30',
                        'online_sinav': 'bg-orange-100 dark:bg-orange-900/30',
                        'gorev': 'bg-teal-100 dark:bg-teal-900/30',
                        'dokuman': 'bg-gray-100 dark:bg-gray-700',
                        'analiz': 'bg-emerald-100 dark:bg-emerald-900/30',
                        'performans': 'bg-yellow-100 dark:bg-yellow-900/30',
                        'kulup': 'bg-green-100 dark:bg-green-900/30'
                    };
                    return classes[type] || classes['dokuman'];
                },

                getIconColorClass(type) {
                    const classes = {
                        'sok': 'text-blue-600 dark:text-blue-400',
                        'bep': 'text-purple-600 dark:text-purple-400',
                        'veli': 'text-pink-600 dark:text-pink-400',
                        'plan': 'text-amber-600 dark:text-amber-400',
                        'gunluk': 'text-cyan-600 dark:text-cyan-400',
                        'zumre': 'text-indigo-600 dark:text-indigo-400',
                        'sinav': 'text-red-600 dark:text-red-400',
                        'online_sinav': 'text-orange-600 dark:text-orange-400',
                        'gorev': 'text-teal-600 dark:text-teal-400',
                        'dokuman': 'text-gray-600 dark:text-gray-400',
                        'analiz': 'text-emerald-600 dark:text-emerald-400',
                        'performans': 'text-yellow-600 dark:text-yellow-400',
                        'kulup': 'text-green-600 dark:text-green-400'
                    };
                    return classes[type] || classes['dokuman'];
                },

                formatDate(dateString) {
                    if (!dateString) return '';
                    const date = new Date(dateString);
                    const now = new Date();
                    const diffTime = Math.abs(now - date);
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                    
                    if (diffDays === 0) return 'Bugün';
                    if (diffDays === 1) return 'Dün';
                    if (diffDays < 7) return diffDays + ' gün önce';
                    if (diffDays < 30) return Math.floor(diffDays / 7) + ' hafta önce';
                    if (diffDays < 365) return Math.floor(diffDays / 30) + ' ay nce';
                    
                    return date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' });
                }
            }
        }
    </script>

    
    </body>
</html>
