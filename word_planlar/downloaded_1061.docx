                                <svg class="w-5 h-5 text-gray-800 dark:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </a>
                            <a href="https://play.google.com/store/apps/details?id=com.defterdoldur.defterdoldur" target="_blank" class="flex items-center justify-between p-4 rounded-lg border-l-4 border-green-600 bg-gray-50 dark:bg-gray-700/50 hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors group">
                                <div class="flex items-center gap-3">
                                    <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5V3.5c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.25-.84-.76-.84-1.35zm13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27zm3.35-4.31c.34.27.64.79.64 1.18 0 .4-.3.91-.64 1.18l-2.02 1.12-2.45-2.45 2.45-2.45 2.02 1.12zM6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z"/></svg>
                                    <span class="font-medium text-gray-700 dark:text-gray-300 text-sm">Google Play'de Değerlendir ⭐</span>
