    <!-- Favicon - Sistem Dark/Light Mode Desteği -->
    <link rel="icon" type="image/png" id="favicon-png" href="https://defterdoldur.com/front/assets/img/logokare.png">
    <link rel="shortcut icon" id="favicon-ico" href="https://defterdoldur.com/front/assets/img/logokare.ico" type="image/x-icon">
    
    <script>
        // Sistem dark/light mode tercihine göre favicon'u ayarla
        (function() {
            function updateFavicon() {
                const isDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                const faviconPng = document.getElementById('favicon-png');
                const faviconIco = document.getElementById('favicon-ico');
                
                if (faviconPng) {
                    faviconPng.href = isDark 
                        ? 'https://defterdoldur.com/front/assets/img/logokaredark.png' 
                        : 'https://defterdoldur.com/front/assets/img/logokare.png';
                }
                if (faviconIco) {
                    faviconIco.href = isDark 
                        ? 'https://defterdoldur.com/front/assets/img/logokare-dark.ico' 
                        : 'https://defterdoldur.com/front/assets/img/logokare.ico';
                }
            }
            
            // Sayfa yüklendiğinde ayarla
            updateFavicon();
            
            // Sistem tercihi değiştiğinde güncelle
            if (window.matchMedia) {
                window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateFavicon);
            }
        })();
    </script>

    
