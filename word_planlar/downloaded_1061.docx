                                                <div class="card overflow-hidden bg-gradient-to-br from-indigo-50 to-blue-50 dark:from-gray-800 dark:to-gray-800 border-b border-indigo-100 dark:border-indigo-900/30" x-data="akademikTakvimComponent()">
    <div class="flex items-center gap-2 px-4 py-3 border-b border-indigo-100 dark:border-indigo-900/30 bg-indigo-100/50 dark:bg-indigo-900/20">
        <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="text-sm font-semibold text-indigo-700 dark:text-indigo-300">Akademik Takvim</span>
        <span class="ml-auto text-xs text-indigo-600 dark:text-indigo-400 bg-indigo-100 dark:bg-indigo-900/40 px-2 py-0.5 rounded-full" x-text="progress.elapsedWeeks + '/' + progress.totalWeeks + ' hafta'"></span>
    </div>
    <div class="p-4">
        
        <div class="flex justify-between text-xs mb-3">
            <span class="px-2 py-1 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 font-medium">
                Geçen: <span x-text="progress.elapsedPercent">0</span>%
            </span>
            <span class="px-2 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 font-medium">
                Kalan: <span x-text="progress.remainingPercent">0</span>%
            </span>
        </div>
        
        <div class="grid grid-cols-10 gap-1">
            <template x-for="(week, i) in progress.weeks" :key="i">
                <div :class="week.type === 'holiday'
                    ? (week.holidayType === 'tatil_yariyil'
                        ? 'bg-rose-300 dark:bg-rose-400/80'
                        : 'bg-orange-300 dark:bg-orange-400/80')
                    : week.type === 'elapsed'
                    ? 'bg-blue-300 dark:bg-blue-400/80'
                    : week.type === 'current'
                    ? 'bg-amber-300 dark:bg-amber-400/90 ring-2 ring-amber-400/50 dark:ring-amber-400/40'
                    : 'bg-emerald-300 dark:bg-emerald-400/80'"
                     class="aspect-square rounded-sm transition-all duration-200 hover:scale-110 cursor-pointer"
                     :title="week.title">
                </div>
            </template>
        </div>
        
        <div class="flex flex-wrap items-center justify-center gap-3 mt-3 text-[10px] text-gray-500 dark:text-gray-400">
            <div class="flex items-center gap-1">
                <div class="w-3 h-3 rounded-sm bg-blue-300 dark:bg-blue-400/80"></div>
                <span>Geçen</span>
            </div>
            <div class="flex items-center gap-1">
                <div class="w-3 h-3 rounded-sm bg-amber-300 dark:bg-amber-400/90 ring-1 ring-amber-400/50"></div>
                <span>Bu Hafta</span>
            </div>
            <div class="flex items-center gap-1">
                <div class="w-3 h-3 rounded-sm bg-emerald-300 dark:bg-emerald-400/80"></div>
                <span>Kalan</span>
